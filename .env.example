# Google OAuth - Get credentials at https://console.cloud.google.com/
# 1. Create a project → APIs & Services → Credentials → OAuth 2.0 Client IDs
# 2. Set Authorized redirect URI to: http://localhost:3000/auth/google/callback (dev)
#                                               and your-production-url/auth/google/callback (prod)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Session secret - use a long random string in production
SESSION_SECRET=change-this-to-something-long-and-random

# Server URL (no trailing slash)
BASE_URL=http://localhost:3000

# Port (optional, defaults to 3000)
PORT=3000

# Node environment
NODE_ENV=development